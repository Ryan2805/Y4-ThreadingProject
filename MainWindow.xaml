<Window x:Class="GymWorkoutTracker.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Gym Workout Tracker"
        Height="740"
        Width="850">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        
        <TextBlock Text="Gym Workout Tracker (Ryan Daly S00237889)"
                   FontSize="17"
                   FontWeight="Bold"
                   Margin="0,0,0,8"/>

        
        <GroupBox Header="Workout Entry Section" Grid.Row="1" Margin="0,0,0,10">
            <StackPanel Margin="8">
                <TextBlock Text="Exercise Name" Margin="0,0,0,3"/>
                <TextBox x:Name="txtExerciseName" Height="26" Margin="0,0,0,8"/>

                <TextBlock Text="Muscle Group" Margin="0,0,0,3"/>
                <TextBox x:Name="txtMuscleGroup" Height="26" Margin="0,0,0,8"/>

                <TextBlock Text="Sets" Margin="0,0,0,3"/>
                <TextBox x:Name="txtSets" Height="26" Margin="0,0,0,8"/>

                <TextBlock Text="Reps" Margin="0,0,0,3"/>
                <TextBox x:Name="txtReps" Height="26" Margin="0,0,0,8"/>

                <TextBlock x:Name="txtWorkoutThreadStatus"
                           Text="Waiting for complete workout input..."
                           Margin="0,4,0,0"/>

                <TextBlock x:Name="txtWorkoutCountdown"
                           Text="Next save in: 10s"
                           Margin="0,2,0,0"/>
            </StackPanel>
        </GroupBox>

        
        <GroupBox Header="Search / Report Section" Grid.Row="2">
            <StackPanel Margin="8">
                <TextBlock Text="Enter Muscle Group to Search" Margin="0,0,0,3"/>
                <TextBox x:Name="txtSearchMuscle" Height="26" Margin="0,0,0,10"/>

                <TextBlock x:Name="txtSearchThreadStatus"
                           Text="Waiting for valid search input..."
                           Margin="0,0,0,2"/>

                <TextBlock x:Name="txtSearchCountdown"
                           Text="Next check in: 5s"
                           Margin="0,0,0,10"/>

                <ProgressBar x:Name="progressBarSearch"
                             Height="22"
                             Minimum="0"
                             Maximum="100"
                             Margin="0,0,0,10"/>

                <ListBox x:Name="lstResults"
                         Height="150"/>
            </StackPanel>
        </GroupBox>

        <!-- BUTTONS MOVED HERE -->
        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Margin="0,10,0,10">

            <Button x:Name="btnLoadStorage"
                    Content="Load From Storage"
                    Width="160"
                    Height="30"
                    Margin="5"
                    Click="btnLoadStorage_Click"/>

            <Button x:Name="btnClearResults"
                    Content="Clear Results"
                    Width="120"
                    Height="30"
                    Margin="5"
                    Click="btnClearResults_Click"/>

            <Button x:Name="btnShowThreadInfo"
                    Content="Show Thread Info"
                    Width="150"
                    Height="30"
                    Margin="5"
                    Click="btnShowThreadInfo_Click"/>
        </StackPanel>

        
        <TextBlock Grid.Row="4"
                   x:Name="txtGeneralStatus"
                   Text="System started."
                   Margin="0,8,0,0"/>
    </Grid>
</Window>